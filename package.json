
{
  "name": "medtrack-pos",
  "description": "Offline-first pharmacy POS system for inventory, sales, and reporting",
  "author": {
    "name": "Nicholas Modi",
    "email": "modinicholas18@gmail.com"
  },
  "homepage": "https://medtrackpos.app",

  "productName": "MedTrack POS",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.ts",
  "type": "module",
    "scripts": {
    "dev": "vite",
    "electron": "electron --disable-gpu --disable-software-rasterizer --ozone-platform=x11 -r ts-node/register electron/main.ts",
    "desktop": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron\"",
    "build": "tsc -b && vite build",
    "dist": "npm run build && electron-builder"
  },

  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1"
  },

  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  },

  "build": {
  "appId": "com.medtrack.pos",
  "productName": "MedTrack POS",
  "files": [
    "dist/**/*",
    "electron/**/*",
    "database/**/*",
    "package.json"
  ],
  "icon": "assets/icon.png",
  "linux": {
    "target": ["AppImage", "deb"],
    "category": "Office",
    "maintainer": "Nicholas Modi <modinicholas18@gmail.com>"
  },
  "win": {
    "target": "nsis"
  }
 }
}